// 以周几为单位的陈述模板

{
    // 瞬时事件的模板
    "temporal": [
        "He [element], and that was on weekday [time]",
        "On weekday [time], he [element]",
        "He [element] on weekday [time]",
        "When it's weekday [time] he [element]",
    ],
    // 时长的模板
    "duration": [
        "He [element] for [duration] day(s)",
        "He [element], and spent [duration] day(s) on it",
        "It takes [duration] day(s) that he [element]",
        "He [element], until [duration] day(s) later",
        "For [duration] day(s), he [element]",
    ],
    // 持续事件的模板
    "durative": [
        // 描述起点和终点
        "From weekday [time] to weekday [endtime], he [element]",
        "On weekday [time] he [element], until weekday [endtime]",
        "He [element] on weekday [time], and ended on weekday [endtime]",
        "He [element] from weekday [time] to weekday [endtime]",
        "weekday [time] to weekday [endtime], he [element]",
        // 描述起点和持续时间
        "From weekday [time] on, he [element] for [duration] day(s)",
        "Starting from weekday [time], he [element] for [duration] day(s)",
        "He [element] since weekday [time], for [duration] day(s)",
        // 描述终点和持续时间
        "He [element] for [duration] day(s) before weekday [endtime]",
        "By weekday [endtime], he [element] for [duration] day(s)",
        "Before weekday [endtime], it's been [duration] day(s) that he [element]",
    ],
    // 时频的模板
    "freq": [
        "From weekday [time] to weekday [endtime], he [element] once every [frequency] day(s)",
        "Over the [duration] day(s) starting from weekday [time], he [element] once every [frequency] day(s)",
        "In the [duration] day(s) before weekday [endtime], he [element] once every [frequency] day(s)",
    ],
    // 事件先后关系的模板
    "before": [
        "He [element1] earlier than [element2]",
        "He [element1] before [element2]",
    ],
    "before_time": [
        "He [element1] [diff] day(s) earlier than [element2]",
        "He [element1] [diff] day(s) before [element2]",
        "[diff] day(s) before [element2], he [element1]",
    ],
    "after": [
        "He [element1] later than [element2]",
        "He [element1] after [element2]",
    ],
    "after_time": [
        "He [element1] [diff] day(s) later than [element2]",
        "He [element1] [diff] day(s) after [element2]",
        "[diff] day(s) after [element2], he [element1]",
    ],
    "simultaneous": [
        "On the day that [element2], he also [element1]",
        "On the same day, not only he [element1], but also [element2]",
        "On the same day as [element2], he also [element1]",
        "On a certain day, both [element2] and [element1] happened",
    ],
    // 事件间隔的模板
    "gap_time": [
        "There are [diff] day(s) between he [element1] and [element2]",
        "The time gap between he [element1] and [element2] is [diff] day(s)",
        "He has a [diff]-day difference between [element1] and [element2]",
    ],
    // 时长关系的模板
    "long": [
        "The total duration that he [element1] is longer than that of [element2]",
        "It takes a longer time that he [element1] than [element2]",
        "Compared to the duration of [element2], more time is taken that he [element1]",
    ],
    "long_time": [
        "[diff] more day(s) are taken that he [element1] than [element2]",
        "The total duration that he [element1] is [diff] day(s) longer than that of [element2]",
        "He takes [diff] more day(s) than [element2] that he [element1]",
    ],
    "short": [
        "The total duration that he [element1] is shorter than that of [element2]",
        "It takes a shorter time that he [element1] than [element2]",
        "Compared to the duration of [element2], less time is taken that he [element1]",
    ],
    "short_time": [
        "[diff] less day(s) are taken that he [element1] than [element2]",
        "The total duration that he [element1] is [diff] day(s) shorter than that of [element2]",
        "He takes [diff] less day(s) than [element2] that he [element1]",
    ],
    "same_len": [
        "He spends the same number of day(s) that he [element1] as [element2]",
        "The time he [element1] is the same length as that [element2]",
        "The time he [element1] is equal to the time duration that [element2]",
        "The time he [element1] matches the time duration of [element2]",
        "He spends the same amount of time that he [element1] and [element2]",
    ],
    // 增加：during的模板
    "during": [
        "During the time that [element2], he also [element1]",
        "He [element1], and that was during the time that [element2]",
        "He [element1] during [element2]",
    ]
}