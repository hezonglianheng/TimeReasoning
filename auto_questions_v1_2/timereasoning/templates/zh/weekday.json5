// 以周几为单位的陈述模板

{
    // 瞬时事件的模板
    "temporal": [
        "他在星期[time][element]",
        "在星期[time]他[element]",
        "他[element]安排在星期[time]", 
        "星期[time]，他[element]",
        "他在周[time][element]",        
        "在周[time]他[element]",
        "他[element]安排在周[time]", 
        "周[time]，他[element]",
    ],
    // 时长的模板
    "duration": [],
    // 持续事件的模板
    "durative": [],
    // 时频的模板
    "freq": [],
    // 事件先后关系的模板
    "before": [
        "[element1]的时间比[element2]早",
        "[element1]是在[element2]之前发生的",
        "[element1]在[element2]之前",
    ],
    "before_time": [
        "[element1]的时间比[element2]早了[diff]天", 
        "在[element2]之前[diff]天，曾[element1]", 
        "在[element2]的[diff]天之前[element1]", 
        "[element1]是在[element2]的[diff]天前", 
        "[element1]是在[element2]之前的第[diff]天发生的",
    ],
    "after": [
        "[element1]的时间比[element2]晚",
        "[element1]是在[element2]之后发生的",
        "[element1]在[element2]之后",
    ],
    "after_time": [
        "[element1]的时间比[element2]晚了[diff]天",
        "在[element2]之后[diff]天，[element1]",
        "在[element2]的[diff]天之后[element1]",
        "[element1]是在[element2]的[diff]天后",
        "[element1]是在[element2]之后的第[diff]天发生的",
    ],
    "simultaneous": [
        "在[element2]的那一天，[element1]",
        "某一天，不仅[element2]，还[element1]",
        "在[element2]的同一天，[element1]",
        "某一天，[element2]和[element1]都发生",
    ],
    // 事件间隔的模板
    "gap_time": [
        "[element2]和[element1]之间相隔[diff]天",
        "[element2]和[element1]之间的时间间隔是[diff]天",
        "[element2]和[element1]中间差了[diff]天",
    ],
    // 时长关系的模板
    "long": [
        "[element1]的时间比[element2]的时间长",
        "[element1]的总时长比[element2]的总时长多",
        "相比[element2]，[element1]用了更多时间",
        "[element1]比[element2]用时更久",
    ],
    "long_time": [
        "[element1]的时间比[element2]的时间长了[diff]天",
        "[element1]的总时长比[element2]的总时长多了[diff]天", 
        "[element1]用了比[element2]多[diff]天的时间",
    ],
    "short": [
        "[element1]的时间比[element2]的时间短",
        "[element1]的总时长比[element2]的总时长少",
        "相比[element2]，[element1]用了更少时间",
        "[element1]比[element2]用时更短",
    ],
    "short_time": [
        "[element1]的时间比[element2]的时间短了[diff]天",
        "[element1]的总时长比[element2]的总时长少了[diff]天", 
        "[element1]用了比[element2]少[diff]天的时间",
    ],
    "same_len": [
        "[element1]的天数和[element2]的天数一样",
        "[element1]的时间和[element2]的时间一样长",
        "[element1]的时间与[element2]所花的时间相同",
        "[element1]花费的时间和[element2]花费的时间相等",
        "[element1]的时长与[element2]的时长一致",
        "[element1]和[element2]用了相同的时间",
    ],
    // 增加：during的模板
    "during": [
        "在[element2]期间，也[element1]",
        "[element1]是在[element2]期间",
        "在[element2]的那段时间里，[element1]",
    ],
}