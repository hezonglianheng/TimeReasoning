// 时间命题陈述模板示例文件
// 模板与命题种类具有对应关系
// 模板中存在占位符，格式为"[占位符名]"，如"[element]"、"[time]"等
// 占位符与相应命题的属性对应
// 模板可以尝试借助LLM生成

{
    // 瞬时事件的模板
    "temporal": [
		"在[time]点，他[element]",
        "他在[time]点[element]",
        "[time]点的时候，他正在[element]",
    ],
    // 时长的模板
    "duration": [
        "他[element]的时间长达[duration]个小时",
		"他花了[duration]个小时[element]",
		"他[element]了[duration]个小时",
		"他用了[duration]个小时[element]",
    ],
    // 持续事件的模板
    "durative": [
        //start to end
        "从[time]点到[endtime]点，他[element]",
		"[time]点到[endtime]点这段时间，他在[element]",
		"他从[time]点开始[element],一直到[endtime]点",
        //start length
        "从[time]点开始，他一直在[element],时间长达[duration]个小时",
		"他从[time]点开始[element],一共花了[duration]个小时",
        //end length
        "他在[endtime]点前的[duration]个小时，一直在[element]",
		"在[endtime]点前，他已经[element]了[duration]个小时",
		"在[endtime]点前，他已经花了[duration]个小时[element]",
    ],
    // 时频的模板
    "freq": [
        "从[time]点到[endtime]点，他每[frequency]个小时都[element]一次",
	    "从[time]点开始的[duration]个小时里，每[frequency]个小时都[element]一次",
	    "他在[endtime]点前的[duration]个小时里，每[frequency]个小时都[element]一次",
    ],
    // 事件先后关系的模板
    "before": [
        "[element1]的时间比[element2]早",
        "[element1]是在[element2]之前发生的",
        "[element1]在[element2]之前",
    ],
    "before_time": [
        "[element1]的时间比[element2]早了[diff]个小时",
        "在[element2]之前的[diff]个小时，[element1]",
        "在[element2]的[diff]个小时之前[element1]",
        "[element1]是在[element2]的[diff]个小时前",
        "[element1]是在[element2]之前的第[diff]个小时发生的",
    ],
    "after": [
        "[element1]的时间比[element2]晚",
        "[element1]是在[element2]之后发生的",
        "[element1]在[element2]之后",
    ],
    "after_time": [
        "[element1]的时间比[element2]晚了[diff]个小时",
        "在[element2]之后的[diff]个小时，[element1]",
        "在[element2]的[diff]个小时后[element1]",
        "[element1]是在[element2]的[diff]个小时后",
        "[element1]是在[element2]之后的第[diff]个小时发生的",
    ],
    "simultaneous": [
        "在[element2]的那个小时，[element1]",
        "某个小时，不仅[element2]，还[element1]",
        "在[element2]的同一个小时，[element1]",
        "某个小时，[element2]和[element1]都发生",
    ],
    // 事件间隔的模板
    "gap_time": [
        "[element2]和[element1]之间相隔[diff]个小时",
        "[element2]和[element1]之间的时间间隔是[diff]个小时",
        "[element2]和[element1]中间差了[diff]个小时",
    ],
    // 时长关系的模板
    "long": [
        "[element1]的时间比[element2]的时间长",
        "[element1]的总时长比[element2]的总时长多",
        "相比[element2]，[element1]用了更多时间",
        "[element1]比[element2]用时更久",
    ],
    "long_time": [
        "[element1]的时间比[element2]的时间长了[diff]个小时",
        "[element1]的总时长比[element2]的总时长多了[diff]个小时",
        "[element1]用了比[element2]多[diff]个小时的时间",
    ],
    "short": [
        "[element1]的时间比[element2]的时间短",
        "[element1]的总时长比[element2]的总时长少",
        "相比[element2]，[element1]用了更少时间",
        "[element1]比[element2]用时更短",
    ],
    "short_time": [
        "[element1]的时间比[element2]的时间短了[diff]个小时",
        "[element1]的总时长比[element2]的总时长少了[diff]个小时",
        "[element1]用了比[element2]少[diff]个小时的时间",
    ],
    "same_len": [
        "[element1]和[element2]花费了相同的时间",
        "[element1]的时间和[element2]的时间一样长",
        "[element1]的时间与[element2]所花的时间相同",
        "[element1]花费的时间和[element2]花费的时间相等",
        "[element1]的时长与[element2]的时长一致",
    ],
    // 增加：during的模板
    "during": [
        "在[element2]期间，也[element1]",
        "[element1]是在[element2]期间",
        "在[element2]的那段时间里，[element1]",
    ]
}